TELEGRAM_BOT_TOKEN=           # From BotFather
TELEGRAM_CHANNEL_ID=          # e.g. @mychannel or -1001234567890
SKY_FORUM_API_KEY=            # Discourse API key (read-only)
X_BEARER_TOKEN=               # Twitter API Bearer token (URL-decoded)
GITHUB_TOKEN=
BRAVE_API_KEY=            # Brave Search API key for organic web coverage
XAI_API_KEY=              # xAI Grok API key — enriches posts before sending                 # Optional - increases GitHub rate limits to 5000/hr
LOG_LEVEL=INFO
TZ=UTC
DB_PATH=data/state.db
SKIP_STARTUP_POLL=false       # Set true to skip poll on first run
DRY_RUN=false                 # Set true to log instead of send to Telegram
